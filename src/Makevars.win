PKG_LIBS = $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)
PKG_CXXFLAGS = -O3
PKG_CPPFLAGS += -DARMA_DONT_USE_WRAPPER -DARMA_NO_DEBUG

# Include directories
PKG_CPPFLAGS += \
  -Ihelper \
  -Imodel_structs \
  -Igp \
  -Ialgs \
  -Itests

# Source files
SOURCES = \
  $(wildcard *.cpp) \
  $(wildcard helper/*.cpp) \
  $(wildcard model_structs/*.cpp) \
  $(wildcard gp/*.cpp) \
  $(wildcard algs/*.cpp) \
  $(wildcard tests/*.cpp)

OBJECTS = $(SOURCES:.cpp=.o)

$(SHLIB): $(OBJECTS)